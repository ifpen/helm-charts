{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "baseBranches": ["develop"],
  "packageRules": [
    {
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["filesender/filesender"],
      "extractVersion": "^v?(?<version>.*)$"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["simplesamlphp/simplesamlphp"],
      "extractVersion": "^v(?<version>.*)$"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG FILESENDER_VERSION=(?<currentValue>.*)"
      ],
      "depNameTemplate": "filesender/filesender",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG SIMPLESAMLPHP_VERSION=(?<currentValue>.*)"
      ],
      "depNameTemplate": "simplesamlphp/simplesamlphp",
      "datasourceTemplate": "github-releases"
    }
  ]
}
